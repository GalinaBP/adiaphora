# Copy to `.env` and adjust. NEVER commit a real `.env`. These are development placeholders only.

# --- Database (used by both the app and the MySQL container) ---
MYSQL_DATABASE=adiaphora
MYSQL_USER=adiaphora
MYSQL_PASSWORD=adiaphora
MYSQL_ROOT_PASSWORD=root

# --- Application datasource (when running the jar directly, not via compose) ---
DB_URL=jdbc:mysql://localhost:3306/adiaphora?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=adiaphora
DB_PASSWORD=adiaphora

# --- JWT secrets: generate strong random values for anything real ---
JWT_ACCESS_SECRET=local-development-access-secret-change-me-01234567890
JWT_REFRESH_SECRET=local-development-refresh-secret-change-me-01234567890

# --- Document storage (development filesystem adapter) ---
DOCUMENT_STORAGE_PATH=./var/documents

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Active Spring profile ---
SPRING_PROFILES_ACTIVE=local
